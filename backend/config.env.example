# Production Environment Variables
# Copy this file to config.env and fill in your values

# Server Configuration
NODE_ENV=production
PORT=5000

# MongoDB Connection (Required)
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/queue_system?retryWrites=true&w=majority

# JWT Configuration (Required)
JWT_SECRET=your_super_long_random_secret_key_minimum_32_characters_long
JWT_EXPIRES_IN=7d
OTP_EXPIRY_MINUTES=10

# SMTP Configuration for Email OTP (Required)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Queue System <noreply@yourdomain.com>

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-domain.com

# Optional: Initial admin email
# INITIAL_ADMIN_EMAIL=admin@yourdomain.com
